.container {
  padding: 40rpx;
}

.ble-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.ble-input-group {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-top: 20rpx;
}

.device-name-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.btn-scan {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  margin: 0;
  background-color: #ff976a;
  color: #fff;
}

.debug-section {
  margin-top: 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.debug-box {
  background-color: #1e1e1e;
  border-radius: 12rpx;
  padding: 20rpx;
  height: 300rpx;
}

.debug-text {
  font-size: 26rpx;
  color: #00ff00;
  font-family: monospace;
  white-space: pre-wrap;
  word-break: break-all;
}